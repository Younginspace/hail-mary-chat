# Dev: client uses relative URLs so every /api/* request goes through the
# Vite dev server, which proxies to VITE_DEV_PROXY_TARGET below. Keeping
# same-origin avoids the cross-origin cookie dance — better-auth can set
# its session cookie on localhost and every subsequent fetch picks it up.
VITE_API_URL=
VITE_DEV_PROXY_TARGET=https://teaching-collie-6315.edgespark.app
